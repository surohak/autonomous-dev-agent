{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/<owner>/autonomous-dev-agent/schema/v1/config.schema.json",
  "title": "autonomous-dev-agent configuration (v1 — frozen)",
  "description": "v1 is a contract. Fields below are stable; removals require a major version bump. New fields MAY be added in minor releases as long as they are optional.",
  "type": "object",
  "required": ["schemaVersion", "owner", "projects"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "description": "Major version of this schema. Agents refuse to start on unknown majors.",
      "type": "integer",
      "const": 1
    },

    "owner": {
      "type": "object",
      "required": ["name", "email"],
      "properties": {
        "name":              { "type": "string", "minLength": 1 },
        "email":             { "type": "string", "format": "email" },
        "slackUserId":       { "type": "string" },
        "voiceLang":         { "type": "string", "description": "BCP-47, e.g. 'en' — used by Whisper transcription" },
        "dailyWorkSeconds":  { "type": "integer", "minimum": 0, "default": 28800 }
      }
    },

    "company": { "type": "string" },

    "time": {
      "type": "object",
      "properties": {
        "tz":       { "type": "string", "description": "IANA TZ (e.g. 'Europe/Berlin')" },
        "digestAt": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" }
      }
    },

    "agent": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "description": "Cursor CLI model slug. Per-project override allowed in projects[].agent.model.",
          "examples": ["claude-opus-4-7-high", "claude-sonnet-4-5"]
        },
        "parallelism": { "type": "integer", "minimum": 1, "maximum": 8, "default": 3 }
      }
    },

    "chat": {
      "type": "object",
      "properties": {
        "kind":     { "type": "string", "enum": ["telegram", "slack"] },
        "tokenEnv": { "type": "string", "description": "env var name in secrets.env holding the bot token" },
        "chatId":   { "type": "string" },
        "chatIdEnv":{ "type": "string" },
        "channel":  { "type": "string", "description": "Slack channel id for 'slack' kind" }
      }
    },

    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name":        { "type": "string" },
          "slackUserId": { "type": "string" },
          "domains":     { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Project identifier — lowercase slug, unique per install.",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name":         { "type": "string" },
          "queueWeight":  { "type": "number", "minimum": 0, "default": 1.0, "description": "Fair-share bias; higher = more priority" },

          "tracker": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind":        { "type": "string", "enum": ["jira-cloud", "github-issues"] },
              "site":        { "type": "string", "format": "uri" },
              "projectKey":  { "type": "string" },
              "repo":        { "type": "string", "description": "github-issues: <owner>/<repo>" }
            }
          },

          "host": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind":   { "type": "string", "enum": ["gitlab", "github"] },
              "site":   { "type": "string", "format": "uri" },
              "group":  { "type": "string" }
            }
          },

          "chat": {
            "type": "object",
            "properties": {
              "kind":      { "type": "string", "enum": ["telegram", "slack"] },
              "tokenEnv":  { "type": "string" },
              "chatIdEnv": { "type": "string" },
              "channel":   { "type": "string" }
            }
          },

          "agent": {
            "type": "object",
            "properties": {
              "model": { "type": "string" }
            }
          },

          "workflow": {
            "type": "object",
            "description": "Project-specific tracker-workflow intent → transition mapping.",
            "properties": {
              "aliases": {
                "type": "object",
                "description": "Semantic intent → tracker transition name. Known intents: start, push_review, after_approve, done, block, unblock.",
                "additionalProperties": { "type": "string" }
              }
            }
          },

          "repositories": {
            "type": "object",
            "description": "alias → { localPath, <host>Project }",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "localPath":      { "type": "string" },
                "gitlabProject":  { "type": "string" },
                "githubRepo":     { "type": "string" },
                "defaultBranch":  { "type": "string", "default": "main" }
              }
            }
          },

          "rebase": {
            "type": "object",
            "properties": {
              "autoResolve": {
                "type": "array",
                "description": "Glob patterns to auto-resolve by taking target-branch version (lock files, translations, generated docs).",
                "items": { "type": "string" }
              }
            }
          },

          "routing": {
            "type": "object",
            "description": "Optional declarative rules for classifying a ticket into a target repo + (optional) reviewer. When present, the executor prompt consults these rules BEFORE falling back to its built-in heuristic. When absent, the built-in heuristic applies. Rules are evaluated top-to-bottom; first match wins. A ticket matches a rule if ANY of its 'when' keywords appear (case-insensitive) in the ticket title, description, or labels.",
            "properties": {
              "defaultRepo": {
                "type": "string",
                "description": "Slug of the repo to use when no rule matches. Must be a key in projects[].repositories. If omitted, the agent asks the user on the chat channel."
              },
              "rules": {
                "type": "array",
                "description": "First-match-wins classification rules.",
                "items": {
                  "type": "object",
                  "required": ["when", "then"],
                  "properties": {
                    "name": { "type": "string", "description": "Human-readable rule name, shown in logs." },
                    "when": {
                      "type": "array",
                      "description": "Keywords/phrases to look for (case-insensitive substring match against title+body+labels). Any-of semantics.",
                      "items": { "type": "string" },
                      "minItems": 1
                    },
                    "then": {
                      "type": "object",
                      "required": ["repo"],
                      "properties": {
                        "repo":     { "type": "string", "description": "Target repo slug (must exist in projects[].repositories)." },
                        "reviewer": { "type": "string", "description": "Optional fixed reviewer. Matches reviewers[].gitlabUsername or reviewers[].name. Overrides domain-based selection." },
                        "branch":   { "type": "string", "description": "Optional override for default target branch for this rule." }
                      }
                    }
                  }
                }
              },
              "askOnAmbiguity": {
                "type": "boolean",
                "default": true,
                "description": "When true, the agent asks on the chat channel if no rule matches and no defaultRepo is set, or if two rules match with equal confidence."
              }
            }
          }
        }
      }
    }
  }
}
